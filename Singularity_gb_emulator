  export LC_ALL=en_US.UTF-8
  export LANG=en_US.UTF-8
  export SDL_AUDIODRIVER=dummy
  export PULSE_SERVER=/dev/null
  if ! infocmp "$TERM" >/dev/null 2>&1; then
    export TERM=xterm-256color
  fi

%runscript
  ROM=$(find /game -maxdepth 1 -name "*.gba" | head -1)
  if [ -z "$ROM" ]; then
    echo "No .gba ROM found in /game/"
    exit 1
  fi
  echo "ROM: $ROM"

  DISPLAY_NUM=99
  while [ -f /tmp/.X${DISPLAY_NUM}-lock ]; do DISPLAY_NUM=$((DISPLAY_NUM+1)); done
  export DISPLAY=":${DISPLAY_NUM}"
  echo "Using display :${DISPLAY_NUM}"

  RENDER_MODE="${RENDER_MODE:-auto}"
  if [ "$RENDER_MODE" = "auto" ]; then
    RENDER_MODE="8bit"
  fi
  echo "Render mode: ${RENDER_MODE}"

  XVFB_RES="480x320"
  echo "Xvfb resolution: ${XVFB_RES}"

  cleanup() {
    kill $MGBA_PID $UNCLUTTER_PID 2>/dev/null
    sleep 0.5
    kill $XVFB_PID 2>/dev/null
    wait 2>/dev/null
    # Copy debug log to game dir for later inspection
    cp /tmp/emulator_debug.log /game/screenshots/debug.log 2>/dev/null
    cp /tmp/ffmpeg_stderr.log /game/screenshots/ffmpeg.log 2>/dev/null
    # Hard reset terminal to clean state
    printf '\033[?25h'
    printf '\033[2J\033[H'
    stty sane 2>/dev/null
    reset 2>/dev/null
    echo ""
    echo "Emulator closed. Debug log saved to screenshots/debug.log"
  }
  trap cleanup EXIT INT TERM

  Xvfb :${DISPLAY_NUM} -screen 0 ${XVFB_RES}x24 +extension RANDR &
  XVFB_PID=$!
  sleep 2
  if ! kill -0 $XVFB_PID 2>/dev/null; then
    echo "Xvfb failed!"; exit 1
  fi
  echo "Xvfb running"

  # Hide the X11 cursor using unclutter (hides after 0s idle, keeps hidden)
  DISPLAY=:${DISPLAY_NUM} unclutter -idle 0 -root &
  UNCLUTTER_PID=$!
  # Also move cursor off-screen as backup
  sleep 0.5
  DISPLAY=:${DISPLAY_NUM} xdotool mousemove --screen 0 9999 9999 2>/dev/null

  DISPLAY=:${DISPLAY_NUM} SDL_VIDEO_WINDOW_POS="0,0" mgba -c /etc/mgba/mgba.ini -f "$ROM" &
  MGBA_PID=$!
  sleep 3
  if ! kill -0 $MGBA_PID 2>/dev/null; then
    echo "mgba failed!"; kill $XVFB_PID 2>/dev/null; exit 1
  fi
  echo "mgba running"

  # Diagnostic: confirm config contents
  echo "--- mGBA config ---"
  cat /etc/mgba/mgba.ini
  echo "---"

  # Diagnostic: test xdotool XTEST on this display
  echo "Testing xdotool..."
  DISPLAY=:${DISPLAY_NUM} xdotool key e 2>&1 && echo "xdotool key: OK" || echo "xdotool key: FAILED"
  DISPLAY=:${DISPLAY_NUM} xdotool getactivewindow 2>&1 && echo "Active window found" || echo "No active window"

  DISPLAY=:${DISPLAY_NUM} import -window root -silent /tmp/.verify.png 2>/dev/null
  if [ -f /tmp/.verify.png ] && [ -s /tmp/.verify.png ]; then
    DIMS=$(identify /tmp/.verify.png 2>/dev/null | grep -oP '\d+x\d+' | head -1)
    echo "Display verified: ${DIMS}"
    cp /tmp/.verify.png /game/screenshots/startup_verify.png 2>/dev/null
    rm -f /tmp/.verify.png
  fi

  clear
  echo "$(basename "$ROM") — ${RENDER_MODE} mode — Ctrl+C to quit"
  sleep 1

  python3 /usr/local/bin/emulator_ui.py "$DISPLAY_NUM" "$RENDER_MODE"

%test
  which mgba     && echo "mgba OK"     || exit 1
  which Xvfb     && echo "Xvfb OK"     || exit 1
  which chafa    && echo "chafa OK"    || exit 1
  which import   && echo "import OK"   || exit 1
  which xdotool  && echo "xdotool OK"  || exit 1
  which img2txt  && echo "img2txt OK"  || exit 1
  python3 -c "from PIL import Image; print('PIL OK')" || exit 1
  echo "Smoke test passed"

%help
  GameBoy Emulator Container v5.5
  ================================
  Controls:
    W/A/S/D = D-Pad    L = A    P = B    E = Start    Q = Select
