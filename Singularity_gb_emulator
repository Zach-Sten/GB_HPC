#!/usr/bin/env python3
"""
Combined renderer + input handler for mGBA in headless X.
v5.4: JPEG, no flicker, all modes, proper cleanup.
"""
import warnings
warnings.filterwarnings("ignore")

import os, sys, time, signal, base64, subprocess, threading, struct, shutil, io

from PIL import Image, ImageDraw, ImageFont

# ===================== DEBUG LOGGING =====================
DEBUG_LOG = "/tmp/emulator_debug.log"
def dbg(msg):
    try:
        with open(DEBUG_LOG, "a") as f:
            f.write(f"[{time.time():.2f}] {msg}\n")
    except:
        pass

DISPLAY_NUM = sys.argv[1] if len(sys.argv) > 1 else "99"
RENDER_MODE = sys.argv[2] if len(sys.argv) > 2 else "8bit"
os.environ["DISPLAY"] = f":{DISPLAY_NUM}"

dbg(f"Starting: display=:{DISPLAY_NUM} mode={RENDER_MODE}")

# Map user keypresses -> mGBA default SDL keybindings
# mGBA defaults: A=X, B=Z, L=A, R=S, Start=Return, Select=BackSpace
# D-pad: Up/Down/Left/Right arrow keys
KEY_MAP = {
    'w': 'Up',      'W': 'Up',       # D-pad up
    'a': 'Left',    'A': 'Left',     # D-pad left
    's': 'Down',    'S': 'Down',     # D-pad down
    'd': 'Right',   'D': 'Right',    # D-pad right
    'l': 'x',       'L': 'x',       # A button
    'p': 'z',       'P': 'z',       # B button
    'e': 'Return',  'E': 'Return',  # Start
    'q': 'BackSpace','Q': 'BackSpace', # Select
    'f': 'a',       'F': 'a',       # L bumper
    'r': 's',       'R': 's',       # R bumper
}

REPEAT_INTERVAL = 0.05
running = True
held_keys = {}
lock = threading.Lock()
mgba_win = None
old_settings = None
fd = None

_frame_count = 0
_fps = 0.0
_fps_last_time = time.time()
_total_frames = 0

# Dynamic terminal size
_term_xpix = 0
_term_ypix = 0
_term_lock = threading.Lock()

# Load font once
try:
    _font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf", 14)
    _font_small = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf", 10)
except:
    _font = ImageFont.load_default()
    _font_small = _font

def update_fps():
    global _frame_count, _fps, _fps_last_time, _total_frames
    _frame_count += 1
    _total_frames += 1
    now = time.time()
    elapsed = now - _fps_last_time
    if elapsed >= 1.0:
        _fps = _frame_count / elapsed
        _frame_count = 0
        _fps_last_time = now
        dbg(f"FPS: {_fps:.1f}  total_frames: {_total_frames}")

def detect_term_pixel_size():
    import fcntl, termios
    for try_fd in [1, 0, 2]:
        try:
            r = fcntl.ioctl(try_fd, termios.TIOCGWINSZ, b'\x00' * 8)
            rows, cols, xpix, ypix = struct.unpack('HHHH', r)
            if xpix > 0 and ypix > 0:
                return xpix, ypix
        except:
            pass
    try:
        tfd = os.open('/dev/tty', os.O_RDONLY)
        import fcntl, termios
        r = fcntl.ioctl(tfd, termios.TIOCGWINSZ, b'\x00' * 8)
        os.close(tfd)
        rows, cols, xpix, ypix = struct.unpack('HHHH', r)
        if xpix > 0 and ypix > 0:
            return xpix, ypix
    except:
        pass
    try:
        sz = shutil.get_terminal_size((120, 40))
        return sz.columns * 14, sz.lines * 34
    except:
        return 1596, 1224

def refresh_term_size():
    global _term_xpix, _term_ypix
    xpix, ypix = detect_term_pixel_size()
    with _term_lock:
        _term_xpix = xpix
        _term_ypix = ypix
    dbg(f"Terminal size: {xpix}x{ypix}")

def get_term_pixel_size():
    with _term_lock:
        return _term_xpix, _term_ypix

def on_sigwinch(signum, frame):
    refresh_term_size()

def find_mgba_window():
    for _ in range(20):
        for pat in ["mGBA", "mgba"]:
            try:
                r = subprocess.run(["xdotool", "search", "--name", pat],
                    capture_output=True, text=True, timeout=2)
                w = r.stdout.strip().split('\n')
                if w and w[0]:
                    dbg(f"Found mGBA window: {w[0]}")
                    return w[0]
            except:
                pass
        try:
            r = subprocess.run(["xdotool", "search", "--onscreen", "--name", ""],
                capture_output=True, text=True, timeout=2)
            w = r.stdout.strip().split('\n')
            if w and w[0]:
                dbg(f"Found window (fallback): {w[0]}")
                return w[0]
        except:
            pass
        time.sleep(1)
    dbg("WARNING: No mGBA window found")
    return None

def xdo(win, key, action="key"):
    # Use XTEST (no --window) so SDL accepts the events.
    # Always use "key" (press+release) for reliability.
    # Explicitly set DISPLAY to make sure xdotool talks to the right X server.
    env = {**os.environ, "DISPLAY": f":{DISPLAY_NUM}"}
    cmd = ["xdotool", "key", "--clearmodifiers", key]
    try:
        subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, env=env)
    except Exception as e:
        dbg(f"xdo FAILED: {cmd} error={e}")

# ===================== KITTY GRAPHICS PROTOCOL =====================

def send_to_kitty(img_data):
    """Send image data via Kitty graphics protocol.
    f=100 auto-detects format (works for both JPEG and PNG).
    No delete — just transmit at cursor home, overwrites previous.
    q=2 suppresses terminal responses."""
    try:
        b64 = base64.b64encode(img_data).decode('ascii')
        # Cursor home — image draws over whatever was there
        out = '\033[H'
        CHUNK = 4096
        chunks = [b64[i:i + CHUNK] for i in range(0, len(b64), CHUNK)]
        for i, chunk in enumerate(chunks):
            last = (i == len(chunks) - 1)
            if i == 0:
                out += f'\033_Ga=T,f=100,q=2,m={0 if last else 1};{chunk}\033\\'
            else:
                out += f'\033_Gm={0 if last else 1};{chunk}\033\\'
        sys.stdout.write(out)
        sys.stdout.flush()
    except Exception as e:
        dbg(f"send_to_kitty error: {e}")

# ===================== JPEG STREAM PARSER =====================

JPEG_SOI = b'\xff\xd8'
JPEG_EOI = b'\xff\xd9'

def read_jpeg_from_stream(stream):
    buf = b''
    while True:
        byte = stream.read(1)
        if not byte:
            return None
        buf += byte
        if buf.endswith(JPEG_SOI):
            jpeg_data = JPEG_SOI
            break
        if len(buf) > 256:
            buf = buf[-2:]
    while True:
        chunk = stream.read(4096)
        if not chunk:
            return None
        jpeg_data += chunk
        idx = jpeg_data.find(JPEG_EOI, len(jpeg_data) - len(chunk) - 2)
        if idx >= 0:
            return jpeg_data[:idx + 2]

# ===================== FRAME PROCESSING =====================

def process_8bit(jpeg_data, xpix, ypix):
    """Upscale with nearest-neighbor, burn FPS, encode JPEG."""
    img = Image.open(io.BytesIO(jpeg_data)).convert('RGB')
    img = img.resize((xpix, ypix), Image.NEAREST)

    # FPS overlay
    draw = ImageDraw.Draw(img)
    fps_text = f"{_fps:.0f} fps"
    tw = len(fps_text) * 9
    th = 16
    margin = 6
    rx = xpix - tw - margin * 2
    ry = margin
    draw.rectangle([rx, ry, rx + tw + margin * 2, ry + th + margin], fill=(0, 0, 0))
    draw.text((rx + margin, ry + margin // 2), fps_text, fill=(0, 255, 0), font=_font)

    buf = io.BytesIO()
    img.save(buf, format='JPEG', quality=75)
    return buf.getvalue()

def process_ascii(jpeg_data, xpix, ypix, mode="ascii"):
    """Convert frame to ASCII art rendered as an image."""
    img = Image.open(io.BytesIO(jpeg_data))

    ascii_cols = min(xpix // 6, 200)
    ascii_rows = min(ypix // 12, 80)
    small = img.resize((ascii_cols, ascii_rows))

    if mode == "bw":
        small = small.convert('L')
    else:
        small = small.convert('RGB')

    chars = " .:-=+*#%@"
    lines = []
    colors = []
    px = small.load()
    for y in range(ascii_rows):
        line = ""
        lc = []
        for x in range(ascii_cols):
            if mode == "bw":
                lum = px[x, y]
                color = (lum, lum, lum)
            else:
                r, g, b = px[x, y]
                lum = int(0.299 * r + 0.587 * g + 0.114 * b)
                color = (r, g, b)
            ci = min(int(lum / 256 * len(chars)), len(chars) - 1)
            line += chars[ci]
            lc.append(color)
        lines.append(line)
        colors.append(lc)

    char_w, char_h = 6, 12
    out_img = Image.new('RGB', (ascii_cols * char_w, ascii_rows * char_h), (0, 0, 0))
    draw = ImageDraw.Draw(out_img)
    for yi, (line, lc) in enumerate(zip(lines, colors)):
        for xi, (ch, col) in enumerate(zip(line, lc)):
            if ch != ' ':
                fill = (255, 255, 255) if mode == "bw" else col
                draw.text((xi * char_w, yi * char_h), ch, fill=fill, font=_font_small)

    out_img = out_img.resize((xpix, ypix), Image.NEAREST)

    buf = io.BytesIO()
    out_img.save(buf, format='JPEG', quality=75)
    return buf.getvalue()

def process_blocks(jpeg_data, xpix, ypix):
    """Pixelated block effect."""
    img = Image.open(io.BytesIO(jpeg_data)).convert('RGB')
    block_w = max(xpix // 8, 60)
    block_h = max(ypix // 8, 40)
    small = img.resize((block_w, block_h), Image.NEAREST)
    out_img = small.resize((xpix, ypix), Image.NEAREST)

    buf = io.BytesIO()
    out_img.save(buf, format='JPEG', quality=75)
    return buf.getvalue()

# ===================== RENDER THREAD =====================

def render_thread():
    """ffmpeg outputs 480x320 JPEG. Python upscales + processes."""

    dbg(f"render_thread: mode={RENDER_MODE}")

    ffmpeg_cmd = [
        "ffmpeg",
        "-f", "x11grab",
        "-video_size", "480x320",
        "-framerate", "30",
        "-i", f":{DISPLAY_NUM}",
        "-f", "image2pipe",
        "-vcodec", "mjpeg",
        "-q:v", "5",
        "pipe:1"
    ]

    dbg(f"ffmpeg cmd: {' '.join(ffmpeg_cmd)}")
    errlog = open("/tmp/ffmpeg_stderr.log", "w")

    try:
        proc = subprocess.Popen(
            ffmpeg_cmd,
            stdout=subprocess.PIPE,
            stderr=errlog
        )
        time.sleep(0.5)

        frame_num = 0
        while running:
            jpeg_data = read_jpeg_from_stream(proc.stdout)
            if not jpeg_data:
                dbg("ffmpeg stream ended")
                break

            frame_num += 1
            if frame_num == 1:
                dbg(f"First frame: {len(jpeg_data)} bytes")
                try:
                    with open("/game/screenshots/first_frame.jpg", "wb") as ff:
                        ff.write(jpeg_data)
                except:
                    pass

            xpix, ypix = get_term_pixel_size()

            try:
                if RENDER_MODE == '8bit':
                    out_data = process_8bit(jpeg_data, xpix, ypix)
                elif RENDER_MODE == 'ascii':
                    out_data = process_ascii(jpeg_data, xpix, ypix, mode='ascii')
                elif RENDER_MODE == 'bw':
                    out_data = process_ascii(jpeg_data, xpix, ypix, mode='bw')
                elif RENDER_MODE == 'blocks':
                    out_data = process_blocks(jpeg_data, xpix, ypix)
                else:
                    out_data = process_8bit(jpeg_data, xpix, ypix)

                if out_data:
                    send_to_kitty(out_data)
            except Exception as e:
                if frame_num < 5:
                    dbg(f"Frame processing error: {e}")

            update_fps()

        proc.kill()
        errlog.close()

        try:
            with open("/tmp/ffmpeg_stderr.log", "r") as f:
                err = f.read()
            if err.strip():
                dbg(f"ffmpeg stderr (last 500):\n{err[-500:]}")
        except:
            pass

    except Exception as e:
        dbg(f"render_thread FATAL: {e}")
        try: errlog.close()
        except: pass

# ===================== INPUT =====================

def key_repeat_thread():
    while running:
        with lock:
            for c in list(held_keys.keys()):
                x = KEY_MAP.get(c)
                if x and mgba_win:
                    xdo(mgba_win, x, "keydown")
        time.sleep(REPEAT_INTERVAL)

# ===================== CLEANUP =====================

def cleanup(*args):
    global running
    running = False
    with lock:
        for c in list(held_keys.keys()):
            x = KEY_MAP.get(c)
            if x and mgba_win:
                xdo(mgba_win, x, "keyup")
        held_keys.clear()
    # Restore TTY FIRST (before any writes)
    if old_settings is not None:
        try:
            import termios
            termios.tcsetattr(fd, termios.TCSANOW, old_settings)
        except:
            pass
    # Clean up display
    try:
        sys.stdout.write('\033_Ga=d;\033\\\033[?25h\033[2J\033[H')
        sys.stdout.flush()
    except:
        pass
    dbg(f"Cleanup complete. Total frames: {_total_frames}")
    sys.exit(0)

# ===================== MAIN =====================

def main():
    global mgba_win, old_settings, fd
    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)
    signal.signal(signal.SIGWINCH, on_sigwinch)

    refresh_term_size()

    fd = sys.stdin.fileno()
    try:
        import termios, tty
        if os.isatty(fd):
            old_settings = termios.tcgetattr(fd)
            tty.setraw(fd)
            dbg("TTY: raw mode on stdin")
        else:
            dbg("stdin not a TTY, trying /dev/tty")
            try:
                tfd = os.open('/dev/tty', os.O_RDONLY | os.O_NOCTTY)
                os.dup2(tfd, fd)
                os.close(tfd)
                old_settings = termios.tcgetattr(fd)
                tty.setraw(fd)
                sys.stdin = os.fdopen(fd, 'r')
                dbg("TTY: raw mode via /dev/tty")
            except Exception as e:
                dbg(f"TTY fallback failed: {e}")
    except Exception as e:
        dbg(f"TTY setup error: {e}")

    sys.stdout.write('\033[2J\033[H\033[?25l')
    sys.stdout.flush()

    mgba_win = find_mgba_window()
    if not mgba_win:
        dbg("ERROR: No mGBA window found")
    else:
        # Focus the window so XTEST events go to it
        try:
            subprocess.run(["xdotool", "windowfocus", "--sync", mgba_win],
                capture_output=True, timeout=5)
            subprocess.run(["xdotool", "windowactivate", "--sync", mgba_win],
                capture_output=True, timeout=5)
            dbg(f"Focused mGBA window: {mgba_win}")
        except Exception as e:
            dbg(f"Failed to focus window: {e}")

    threading.Thread(target=render_thread, daemon=True).start()
    threading.Thread(target=key_repeat_thread, daemon=True).start()

    import select as sel
    last_time = 0
    _input_log_count = 0
    while running:
        try:
            rlist, _, _ = sel.select([fd], [], [], 0.01)
            if rlist:
                try:
                    raw = os.read(fd, 256)
                except (BlockingIOError, OSError):
                    raw = b''
            else:
                raw = b''

            if raw:
                # Log raw bytes received
                _input_log_count += 1
                if _input_log_count <= 50:
                    dbg(f"INPUT raw ({len(raw)} bytes): {raw.hex()} repr={repr(raw)}")

                i = 0
                chars = []
                while i < len(raw):
                    b = raw[i]
                    if b == 0x1b:
                        # Escape sequence — determine type and skip entirely
                        esc_start = i
                        i += 1
                        if i < len(raw):
                            next_b = raw[i]
                            if next_b == ord('_') or next_b == ord(']'):
                                # APC (\x1b_) or OSC (\x1b]) sequence
                                # These run until String Terminator: \x1b\\
                                i += 1  # skip the _ or ]
                                while i < len(raw):
                                    if raw[i] == 0x1b and (i + 1) < len(raw) and raw[i + 1] == ord('\\'):
                                        i += 2  # skip \x1b\\
                                        break
                                    i += 1
                            elif next_b == ord('['):
                                # CSI sequence: \x1b[ ... ends at alpha char
                                i += 1  # skip [
                                while i < len(raw):
                                    c = raw[i]
                                    i += 1
                                    if c >= ord('@') and c <= ord('~'):
                                        break
                            else:
                                # Other escape: skip until alpha or backslash
                                i += 1
                                while i < len(raw):
                                    c = raw[i]
                                    i += 1
                                    if c == ord('\\') or (c >= ord('A') and c <= ord('z')):
                                        break
                        if _input_log_count <= 50:
                            dbg(f"INPUT skipped escape ({i - esc_start} bytes): {raw[esc_start:i].hex()}")
                    elif b == 0x03:
                        dbg("INPUT: Ctrl+C received")
                        cleanup()
                    else:
                        chars.append(chr(b))
                        i += 1

                if chars and _input_log_count <= 50:
                    dbg(f"INPUT parsed chars: {chars}")

                for char in chars:
                    if char in KEY_MAP:
                        mapped = KEY_MAP[char]
                        with lock:
                            if char not in held_keys:
                                if mgba_win:
                                    dbg(f"INPUT keydown: '{char}' -> xdotool keydown '{mapped}' to window {mgba_win}")
                                    xdo(mgba_win, mapped, "keydown")
                                else:
                                    dbg(f"INPUT keydown: '{char}' but NO mgba_win!")
                                held_keys[char] = True
                        last_time = time.time()
                    else:
                        if _input_log_count <= 50:
                            dbg(f"INPUT char '{char}' (0x{ord(char):02x}) not in KEY_MAP")
            else:
                if time.time() - last_time > REPEAT_INTERVAL * 3:
                    with lock:
                        for c in list(held_keys.keys()):
                            x = KEY_MAP.get(c)
                            if x and mgba_win:
                                xdo(mgba_win, x, "keyup")
                        held_keys.clear()

        except Exception as e:
            dbg(f"INPUT loop exception: {e}")

if __name__ == "__main__":
    main()
UIPY
